<Window x:Class="Sutra.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Sutra Reader" Height="800" Width="1200">
    <Window.Resources>
        <Style x:Key="TabCloseButtonStyle" TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Transparent" CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="Red"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#F3F3F3" BorderBrush="#DDD" BorderThickness="0,0,1,0">
            <StackPanel Margin="10">
                <Grid Margin="0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" 
                            Content="New Tab"
                            Click="NewTab_Click"
                            Margin="1,0,0,0"
                            FontSize="11"
                            Padding="1"/>
                    <Button Grid.Column="1"
                            Content="Alice"
                            Click="SidebarBookmark_Click"
                            Tag="https://alice.yandex.ru"
                            Margin="1,0,0,0"
                            FontSize="11"
                            Padding="1"/>
                    <Button Grid.Column="2" 
                     Content="Gemini" 
                     Click="SidebarBookmark_Click"
                     Tag="https://gemini.google.com"
                     Margin="1,0,0,0"
                     FontSize="11"
                     Padding="1"/>
                </Grid>
                <TextBlock x:Name="RssTimerText" Text="Updating in: --:--" FontSize="11" Foreground="#0288D1" Margin="0,0,0,5"/>
                <TextBox x:Name="RssUrlInput" Margin="0,2" ToolTip="Enter RSS URL"/>
                <Grid Margin="0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" 
                     Content="Subscribe" 
                     Click="SubscribeRss_Click" 
                     Margin="0,0,1,0" 
                     Padding="1"
                     FontSize="11"
                     Background="#E1F5FE"/>

                    <Button Grid.Column="1" 
                     Content="Reader" 
                     Click="ViewRss_Click" 
                     Margin="1,0,1,0"
                     FontSize="11"
                     Padding="1"/>

                    <Button Grid.Column="2" 
                     Content="Update" 
                     Click="UpdateRss_Click" 
                     Margin="1,0,0,0"
                     FontSize="11"
                     Padding="1"
                     Background="#E8F5E9"/>
                </Grid>
            </StackPanel>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#EEE" BorderBrush="#DDD" BorderThickness="0,0,0,1" Padding="5">
                <StackPanel Orientation="Horizontal">
                    <Button Content="←" Width="30" Margin="2" Click="Back_Click"/>
                    <Button Content="→" Width="30" Margin="2" Click="Forward_Click"/>
                    <Button Content="↻" Width="30" Margin="2" Click="Reload_Click"/>
                    <Button Content="⌂" Width="30" Margin="2" Click="Home_Click"/>

                    <TextBox x:Name="UrlTextBox" Width="500" Margin="5,2" VerticalContentAlignment="Center" 
                 KeyDown="UrlTextBox_KeyDown"/>

                    <Button Content="Go" Width="50" Margin="2" Click="Go_Click"/>
                </StackPanel>
            </Border>

            <TabControl x:Name="BrowserTabs" Grid.Row="1">
            </TabControl>
        </Grid>
    </Grid>
</Window>
